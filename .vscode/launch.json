{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "mule-xml-debugger",
      "request": "launch",
      "name": "Run Mule Application",
      "noDebug": true,
      "mule.projects": [
        "${workspaceFolder}"
      ],
      "mule.runtime.args": "${config:mule.runtime.defaultArguments}"
    },
    {
      "type": "mule-xml-debugger",
      "request": "launch",
      "name": "Debug Mule Application",
      "noDebug": false,
      "mule.projects": [
        "${workspaceFolder}"
      ],
      "mule.runtime.args": "${config:mule.runtime.defaultArguments}"
    }
  ]
}