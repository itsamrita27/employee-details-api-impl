#%RAML 1.0 DataType
displayName: Employee
description: Represents the core employee entity with all its attributes.

type: object
properties:
  id:
    displayName: Employee ID
    description: Unique numeric identifier for the employee.
    type: number
    required: true
    example: 1001
  name:
    displayName: Employee Name
    description: Full name of the employee.
    type: string
    required: true
    minLength: 1
    maxLength: 100
    example: John Doe
  salary:
    displayName: Salary
    description: Monthly salary of the employee in USD.
    type: number
    required: true
    minimum: 0
    example: 75000
  location:
    displayName: Location
    description: Office location or city where the employee is based.
    type: string
    required: true
    minLength: 1
    maxLength: 100
    example: New York